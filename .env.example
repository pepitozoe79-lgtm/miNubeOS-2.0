# ============================================================
#  miNubeOS - Configuración de Entorno
# ============================================================
#  Copia este archivo a backend/.env y personaliza los valores.
#
#  cp .env.example backend/.env
# ============================================================

# Puerto del servidor backend
PORT=3000

# Clave secreta para firmar tokens JWT (¡CÁMBIALA!)
# Genera una con: head /dev/urandom | tr -dc A-Za-z0-9 | head -c 32
JWT_SECRET=cambia-esto-por-una-clave-segura

# Ruta de la base de datos SQLite
DB_PATH=../data/db/nubeos.sqlite

# Modo de ejecución: development | production
NODE_ENV=development
